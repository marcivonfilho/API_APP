OPENAI_API_KEY=
LLAMA_CLOUD_API_KEY=
GOOGLE_API_KEY=

RAG_EMBED_PROVIDER=openai
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMENSION=1536
OPENAI_CHAT_MODEL=gpt-5-mini
RAG_N_RESULTS=6
RAG_FETCH_K=18
RAG_CONTEXT_MAX_CHARS=14000
RAG_MAX_DOC_CHARS=2800
RAG_MAX_OUTPUT_TOKENS=1200

CHROMA_PATH=vector_db/chroma_db

# Use DATABASE_URL in containers when the database is another service.
# Example: postgresql://app_user:change-me@postgres:5432/app_ventos
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app_ventos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

PROCESSED_IMAGES_DIR=images_processed
